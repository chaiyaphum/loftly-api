# Loftly API — environment variables
# See ../loftly/mvp/DEPLOYMENT.md §Environment variables

# --- Required ---
DATABASE_URL=postgresql+asyncpg://loftly:loftly@localhost:5432/loftly
JWT_SIGNING_KEY=change-me-to-a-32-byte-random-string

# --- Strongly recommended ---
REDIS_URL=redis://localhost:6379/0
LOFTLY_ENV=dev

# --- JWT config (defaults ok) ---
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- LLM provider switch (deterministic | anthropic) ---
LOFTLY_LLM_PROVIDER=deterministic

# --- AI providers (optional in dev; stub when unset or set to "stub") ---
ANTHROPIC_API_KEY=
TYPHOON_API_KEY=
TYPHOON_API_BASE=https://api.sambanova.ai/v1

# --- OAuth providers (optional; endpoints return 503 when unset) ---
LOFTLY_OAUTH_GOOGLE_CLIENT_ID=
LOFTLY_OAUTH_GOOGLE_CLIENT_SECRET=
LOFTLY_OAUTH_APPLE_CLIENT_ID=
LOFTLY_OAUTH_APPLE_TEAM_ID=
LOFTLY_OAUTH_APPLE_KEY_ID=
LOFTLY_OAUTH_APPLE_PRIVATE_KEY=
LOFTLY_OAUTH_LINE_CLIENT_ID=
LOFTLY_OAUTH_LINE_CLIENT_SECRET=

# --- deal-harvester sync (optional in dev) ---
DEAL_HARVESTER_BASE=https://deals.biggo-analytics.dev/api/v1
DEAL_HARVESTER_API_KEY=

# --- Observability (optional) ---
SENTRY_DSN=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://langfuse.internal.loftly.co.th
POSTHOG_PROJECT_API_KEY=

# --- Email (optional in dev; log-only when unset) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=Loftly <noreply@loftly.co.th>

# --- Prompt versioning (optional rollback pin) ---
LOFTLY_PROMPT_VERSION_OVERRIDE=

# --- Affiliate partner secrets (JSON map partner_id -> shared_secret) ---
# Example: AFFILIATE_PARTNER_SECRETS='{"bigbank-affiliate":"xxx"}'
AFFILIATE_PARTNER_SECRETS=
