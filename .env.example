# Loftly API — environment variables
# See ../loftly/mvp/DEPLOYMENT.md §Environment variables

# --- Required ---
DATABASE_URL=postgresql+asyncpg://loftly:loftly@localhost:5432/loftly
JWT_SIGNING_KEY=change-me-to-a-32-byte-random-string

# --- Strongly recommended ---
REDIS_URL=redis://localhost:6379/0
LOFTLY_ENV=dev

# --- JWT config (defaults ok) ---
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# --- AI providers (optional in dev; warn but don't block) ---
ANTHROPIC_API_KEY=
TYPHOON_API_KEY=
TYPHOON_API_BASE=https://api.sambanova.ai/v1

# --- deal-harvester sync (optional in dev) ---
DEAL_HARVESTER_BASE=https://deals.biggo-analytics.dev/api/v1
DEAL_HARVESTER_API_KEY=

# --- Observability (optional) ---
SENTRY_DSN=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://langfuse.internal.loftly.co.th
POSTHOG_PROJECT_API_KEY=

# --- Email (optional in dev) ---
RESEND_API_KEY=

# --- Prompt versioning (optional rollback pin) ---
LOFTLY_PROMPT_VERSION_OVERRIDE=
